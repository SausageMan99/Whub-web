# Web / Vercel
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Worker / VPS
SUPABASE_URL=
WORKER_NAME=whub-cv-worker-01
POLL_INTERVAL_SECONDS=10
MAX_ATTEMPTS=3

CV_SOURCES_BUCKET=cv-sources
CV_RENDERER_INPUTS_BUCKET=cv-renderer-inputs
CV_FINALS_BUCKET=cv-finals
CV_ARTIFACTS_BUCKET=cv-artifacts

HERMES_CLI_PATH=hermes
HERMES_PROFILE=default
WHUB_RENDERER_PATH=/root/.hermes/scripts/whub_cv_renderer.py
WHUB_ASSETS_DIR=/root/.hermes/image_cache
WHUB_FONTS_DIR=/tmp/poppins_full
TMP_DIR=/tmp/whub-cv-factory
LOG_LEVEL=INFO

# MVP whitelist: add 4-5 W hub users in Supabase allowed_users table, not here.
